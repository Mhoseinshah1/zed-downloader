# ==================================================================
# zed-downloader — environment configuration
#
# Copy this file to `.env` at the repository root. The installer
# (scripts/install.sh) does this for you and fills in the secrets.
# One single .env is consumed by every service (api, worker, bot,
# postgres, proxy) through docker-compose `env_file`.
# ==================================================================

# --- General -------------------------------------------------------
# Public domain with an A record pointing at this server.
# Caddy obtains a Let's Encrypt certificate for it automatically.
DOMAIN=example.com
# E-mail used for the Let's Encrypt / ACME account.
ACME_EMAIL=admin@example.com
TZ=Asia/Tehran

# --- PostgreSQL ----------------------------------------------------
POSTGRES_DB=zed_downloader
POSTGRES_USER=zed
POSTGRES_PASSWORD=change-me
# Async SQLAlchemy URL used by api + worker. Host "postgres" is the
# compose service name — keep it unless you run an external DB.
DATABASE_URL=postgresql+asyncpg://zed:change-me@postgres:5432/zed_downloader

# --- Redis ---------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Security ------------------------------------------------------
# JWT signing secret for admin-panel auth (HS256).
# Generate: openssl rand -hex 32
JWT_SECRET=change-me
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=7
# Fernet key used to encrypt provider API keys at rest.
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# Shared secret. Used both as the Telegram webhook secret_token and as
# the X-Internal-Secret header for bot -> api internal calls.
# Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=change-me

# --- Telegram bot --------------------------------------------------
BOT_TOKEN=123456:replace-with-botfather-token
BOT_USERNAME=my_downloader_bot
# polling (default) or webhook
RUN_MODE=polling
# Public base URL for webhook mode, e.g. https://example.com
WEBHOOK_BASE_URL=
WEBHOOK_PORT=8080
# Bot -> API base URL (compose service name).
API_BASE_URL=http://api:8000

# --- Owner admin (seeded on first API start) ------------------------
OWNER_ADMIN_EMAIL=admin@example.com
OWNER_ADMIN_PASSWORD=change-me
OWNER_TELEGRAM_ID=0

# --- Download limits ------------------------------------------------
# Self-hosted telegram-bot-api server URL (v2 TODO: ship one in compose),
# e.g. http://telegram-api:8081. Leave empty to use api.telegram.org.
TELEGRAM_API_URL=
# NOTE: the standard Telegram Bot API caps bot uploads at ~50 MB, so while
# TELEGRAM_API_URL is empty the effective limit is min(MAX_FILE_SIZE_MB, 50).
# The 1900 MB value only takes effect with a self-hosted Bot API server.
MAX_FILE_SIZE_MB=1900
MAX_DURATION_SECONDS=7200
DOWNLOAD_TIMEOUT_SECONDS=600
FREE_DOWNLOADS_PER_DAY=3
TEMP_DIR=/tmp/zed-downloads

# --- Payments: Zarinpal ---------------------------------------------
ZARINPAL_MERCHANT_ID=
# true = use sandbox.zarinpal.com (test payments), false = production.
ZARINPAL_SANDBOX=true
# Base URL Zarinpal redirects back to after payment.
# Defaults to https://$DOMAIN when empty.
PAYMENT_CALLBACK_BASE_URL=

# --- API ------------------------------------------------------------
CORS_ORIGINS=*
